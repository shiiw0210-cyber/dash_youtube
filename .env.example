# YouTube Data API v3 key
# Get it from https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# 監視対象の YouTube チャンネル ID（Cron ジョブが参照します）
YOUTUBE_CHANNEL_ID=UCmxAaack6dmXAxwgnhzX0MQ

# LINE Messaging API（公式 LINE アカウント）
# LINE Developers のチャンネル基本設定から取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# Bot を招待したグループ LINE の ID（C から始まる）
LINE_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 再生数の閾値（24時間時点でこの回数以下なら通知）
LOW_VIEW_THRESHOLD=350

# Vercel Cron から呼ばれる際の Authorization ヘッダー検証用シークレット
# 任意の長いランダム文字列を設定
CRON_SECRET=change_me_to_a_random_string

# Google Apps Script Web App for スケジュールシート連携
# gas/Code.gs を対象スプレッドシートの Apps Script に貼り付けてデプロイし、
# 発行された exec URL を設定する
GAS_WEB_APP_URL=https://script.google.com/macros/s/AKfycbx.../exec
# GAS のスクリプトプロパティ SHARED_SECRET と同じ値
GAS_SHARED_SECRET=change_me_to_a_long_random_string
